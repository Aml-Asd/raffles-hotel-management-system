@startuml Online Bookstore Management System

' Set vertical layout
top to bottom direction

skinparam actorStyle awesome
skinparam usecase {
    BackgroundColor LightBlue
    BorderColor DarkBlue
    ArrowColor DarkBlue
}

' Actors
actor "New Customer" as NewCustomer #LightBlue
actor "Returning Customer" as ReturningCustomer #LightBlue
actor "Store Manager" as StoreManager #LightGreen
actor "Supplier" as Supplier #LightYellow

' Use Cases for Customers
usecase "Register" as UC1
usecase "Login" as UC2
usecase "Browse Books" as UC3
usecase "Search Books" as UC4
usecase "View Book Details" as UC5
usecase "Add to Cart" as UC6
usecase "Select Quantity" as UC7
usecase "View Shopping Cart" as UC8
usecase "Checkout" as UC9
usecase "Apply Discount Code" as UC10
usecase "Enter Card Info" as UC11
usecase "Make Payment" as UC12
usecase "Track Order" as UC13
usecase "View Recommendations" as UC14
usecase "Write a Review" as UC15

' Use Cases for Store Manager
usecase "Add Books" as UC16
usecase "Update Books" as UC17
usecase "Delete Books" as UC18
usecase "View Orders" as UC19
usecase "Manage Users" as UC20
usecase "Update Order Status" as UC21
usecase "Create Promotions" as UC22

' Use Cases for Supplier
usecase "Order Book from Supplier" as UC23
usecase "Confirm Order" as UC24
usecase "Check Current Order" as UC25

' Relationships for Customers
NewCustomer --> UC1
ReturningCustomer --> UC2
NewCustomer --> UC3
ReturningCustomer --> UC3
NewCustomer --> UC4
ReturningCustomer --> UC4
NewCustomer --> UC5
ReturningCustomer --> UC5
NewCustomer --> UC6
ReturningCustomer --> UC6
NewCustomer --> UC8
ReturningCustomer --> UC8
NewCustomer --> UC9
ReturningCustomer --> UC9
NewCustomer --> UC13
ReturningCustomer --> UC13
NewCustomer --> UC14
ReturningCustomer --> UC14
NewCustomer --> UC15
ReturningCustomer --> UC15

UC6 --> UC7 : <<include>>
UC9 --> UC10 : <<extend>>
UC9 --> UC11 : <<include>>
UC9 --> UC12 : <<include>>
UC4 --> UC14 : <<extend>>
UC5 --> UC15 : <<extend>>

' Relationships for Store Manager
StoreManager --> UC16
StoreManager --> UC17
StoreManager --> UC18
StoreManager --> UC19
StoreManager --> UC20
StoreManager --> UC21
StoreManager --> UC22

' Relationships for Supplier
Supplier --> UC23
Supplier --> UC24
Supplier --> UC25

' Vertical alignment for clarity
UC1 -down-> UC2
UC2 -down-> UC3
UC3 -down-> UC4
UC4 -down-> UC5
UC5 -down-> UC6
UC6 -down-> UC7
UC7 -down-> UC8
UC8 -down-> UC9
UC9 -down-> UC10
UC10 -down-> UC11
UC11 -down-> UC12
UC12 -down-> UC13
UC13 -down-> UC14
UC14 -down-> UC15

@enduml 